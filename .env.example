# Copy to `.env.local` for local Next.js development (see README).

# --- Gemini (required) ---
# Create an API key in Google AI Studio or Google Cloud Console.
NEXT_PUBLIC_GEMINI_API_KEY=

# --- Firebase web app (required for auth + Firestore) ---
# Firebase console → Project settings → Your apps → Firebase SDK snippet (config).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore: `(default)` for the default database, or the named database ID from Firebase console.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)

# Optional: canonical app URL for hosted deployments (OAuth callbacks, links).
APP_URL=
